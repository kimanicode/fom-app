generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  supabaseAuthId String @unique
  email        String   @unique
  passwordHash String
  name         String?
  alias        String?
  ageRange     String?
  city         String?
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interests   UserInterest[]
  questsCreated QuestTemplate[] @relation("QuestCreator")
  createdInstances QuestInstance[] @relation("QuestInstanceCreator")
  participants QuestParticipant[]
  checkins    Checkin[]
  posts       Post[]
  likes       Like[]
  saves       Save[]
  ratings     Rating[]
  notifications Notification[]
  messages    ChatMessage[]
  paymentsMade PaymentTransaction[] @relation("PaymentPayer")
  payoutsEarned PaymentTransaction[] @relation("PaymentCreator")
  withdrawalRequests WithdrawalRequest[]
  preferenceProfile UserPreferenceProfile?
  behaviorSignals UserBehaviorSignal[]

  reports     Report[] @relation("Reporter")
  reportedBy  Report[] @relation("ReportedUser")

  blocks      Block[] @relation("Blocker")
  blockedBy   Block[] @relation("Blocked")
}

model InterestTag {
  id       String         @id @default(uuid())
  name     String
  slug     String         @unique
  group    String         @default("interest")
  level    InterestLevel?
  parentId String?
  metadata Json?
  parent   InterestTag?   @relation("InterestHierarchy", fields: [parentId], references: [id])
  children InterestTag[]  @relation("InterestHierarchy")
  users    UserInterest[]
  quests   QuestInterest[]
  categoryQuests QuestTemplate[] @relation("QuestCategory")
  subcategoryQuests QuestTemplate[] @relation("QuestSubcategory")

  @@unique([group, name, parentId])
}

model UserInterest {
  userId String
  tagId  String
  source InterestSource @default(explicit)
  weight Float @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  tag  InterestTag @relation(fields: [tagId], references: [id])

  @@id([userId, tagId])
}

model Location {
  id        String   @id @default(uuid())
  placeName String
  lat       Float
  lng       Float
  category  String?
  createdAt DateTime @default(now())

  quests QuestTemplate[]
  instances QuestInstance[]
  posts  Post[]
}

model QuestTemplate {
  id              String   @id @default(uuid())
  creatorId       String
  title           String
  description     String
  vibeTag         String
  imageUrl        String?
  locationId      String
  startTime       DateTime
  durationMinutes Int
  maxParticipants Int
  cost            String   @default("free")
  costAmountCents Int      @default(0)
  currency        String   @default("USD")
  categoryId      String?
  subcategoryId   String?
  intentTags      String[]
  vibeTags        String[]
  audienceTags    String[]
  locationTags    String[]
  timeTags        String[]
  priceTag        String?
  metadataQualityScore Float @default(0)
  enrichedCategory String?
  audienceType    String?
  energyLevel     String?
  indoorOutdoor   String?
  enrichmentTags  String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator  User     @relation("QuestCreator", fields: [creatorId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  categoryTag InterestTag? @relation("QuestCategory", fields: [categoryId], references: [id])
  subcategoryTag InterestTag? @relation("QuestSubcategory", fields: [subcategoryId], references: [id])

  instances QuestInstance[]
  saves     Save[]
  reports   Report[] @relation("ReportedQuest")
  payments  PaymentTransaction[]
  interestTags QuestInterest[]
  behaviorSignals UserBehaviorSignal[]
}

model QuestInstance {
  id              String   @id @default(uuid())
  templateId      String?
  creatorId       String?
  startTime       DateTime
  durationMinutes Int
  locationId      String
  status          String   @default("scheduled")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template  QuestTemplate? @relation(fields: [templateId], references: [id])
  creator   User?          @relation("QuestInstanceCreator", fields: [creatorId], references: [id])
  location  Location       @relation(fields: [locationId], references: [id])

  participants QuestParticipant[]
  posts        Post[]
  ratings      Rating[]
  checkins     Checkin[]
  messages     ChatMessage[]
  payments     PaymentTransaction[]
}

model QuestParticipant {
  id         String   @id @default(uuid())
  instanceId String
  userId     String
  joinedAt   DateTime @default(now())
  role       String   @default("participant")

  instance QuestInstance @relation(fields: [instanceId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@unique([instanceId, userId])
}

model Checkin {
  id         String   @id @default(uuid())
  instanceId String
  userId     String
  checkedInAt DateTime @default(now())
  lat        Float
  lng        Float

  instance QuestInstance @relation(fields: [instanceId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@unique([instanceId, userId])
}

model Post {
  id              String   @id @default(uuid())
  instanceId      String
  userId          String
  locationId      String
  mediaUrl        String
  mediaType       String
  durationSeconds Int?
  caption         String?
  createdAt       DateTime @default(now())

  instance QuestInstance @relation(fields: [instanceId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  location Location      @relation(fields: [locationId], references: [id])

  likes   Like[]
  reports Report[] @relation("ReportedPost")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Save {
  id        String   @id @default(uuid())
  questId   String
  userId    String
  createdAt DateTime @default(now())

  quest QuestTemplate @relation(fields: [questId], references: [id])
  user  User          @relation(fields: [userId], references: [id])

  @@unique([questId, userId])
}

model Rating {
  id         String   @id @default(uuid())
  instanceId String
  userId     String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  instance QuestInstance @relation(fields: [instanceId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@unique([instanceId, userId])
}

model Report {
  id             String   @id @default(uuid())
  reporterId     String
  reportedUserId String?
  reportedQuestId String?
  reportedPostId String?
  reason         String
  createdAt      DateTime @default(now())

  reporter     User           @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser User?          @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedQuest QuestTemplate? @relation("ReportedQuest", fields: [reportedQuestId], references: [id])
  reportedPost Post?          @relation("ReportedPost", fields: [reportedPostId], references: [id])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model ChatMessage {
  id         String   @id @default(uuid())
  instanceId String
  userId     String
  text       String
  createdAt  DateTime @default(now())

  instance QuestInstance @relation(fields: [instanceId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@index([instanceId, createdAt])
}

model QuestInterest {
  id      String @id @default(uuid())
  questId String
  tagId   String
  weight  Float  @default(1)
  source  String @default("creator")
  createdAt DateTime @default(now())

  quest QuestTemplate @relation(fields: [questId], references: [id])
  tag   InterestTag   @relation(fields: [tagId], references: [id])

  @@unique([questId, tagId])
  @@index([tagId, questId])
}

model UserPreferenceProfile {
  userId String @id
  selectedCategoryIds String[]
  selectedSubcategoryIds String[]
  selectedInterestIds String[]
  intentTags String[]
  vibePreferences String[]
  audienceAffinities String[]
  locationPreferences String[]
  timePreferences String[]
  pricePreferences String[]
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model UserBehaviorSignal {
  id         String @id @default(uuid())
  userId     String
  questId    String?
  signalType BehaviorSignalType
  strength   Float @default(1)
  context    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  quest QuestTemplate? @relation(fields: [questId], references: [id])

  @@index([userId, createdAt])
  @@index([questId, signalType])
}

model PaymentTransaction {
  id               String   @id @default(uuid())
  questId          String
  questInstanceId  String
  payerId          String
  creatorId        String
  amountCents      Int
  platformFeeCents Int
  creatorAmountCents Int
  currency         String   @default("USD")
  status           String   @default("captured")
  paymentMethod    String?
  providerRef      String?
  createdAt        DateTime @default(now())

  quest   QuestTemplate @relation(fields: [questId], references: [id])
  questInstance QuestInstance @relation(fields: [questInstanceId], references: [id])
  payer   User @relation("PaymentPayer", fields: [payerId], references: [id])
  creator User @relation("PaymentCreator", fields: [creatorId], references: [id])

  @@unique([questId, payerId])
  @@unique([questInstanceId, payerId])
  @@index([creatorId, createdAt])
}

model WithdrawalRequest {
  id          String   @id @default(uuid())
  creatorId   String
  amountCents Int
  currency    String   @default("USD")
  destination String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  processedAt DateTime?

  creator User @relation(fields: [creatorId], references: [id])

  @@index([creatorId, createdAt])
}

enum InterestLevel {
  category
  subcategory
  interest
}

enum InterestSource {
  explicit
  inferred
}

enum BehaviorSignalType {
  viewed
  saved
  joined
  paid
  dismissed
}
